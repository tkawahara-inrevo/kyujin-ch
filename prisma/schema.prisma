// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  COMPANY
  ADMIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERN
  OTHER
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  INTERVIEW
  OFFER
  REJECTED
  HIRED
}

enum MessageSenderType {
  USER
  COMPANY
  ADMIN
}

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  password             String?
  role                 UserRole @default(USER)
  phone                String?
  resumeUrl            String?
  careerHistoryUrl     String?
  notificationsEnabled Boolean  @default(true)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  applications Application[]
  bookmarks    Bookmark[]
  favorites    Favorite[]
  reviews      Review[]
  company      Company?   @relation("CompanyUser")
}

model Company {
  id            String   @id @default(cuid())
  name          String
  description   String?
  websiteUrl    String?
  location      String?
  isActive      Boolean  @default(true)
  companyUserId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyUser     User?            @relation("CompanyUser", fields: [companyUserId], references: [id])
  jobs            Job[]
  reviews         Review[]
  invalidRequests InvalidRequest[]
  monthlyBillings MonthlyBilling[]
}

model Job {
  id             String         @id @default(cuid())
  companyId      String
  title          String
  description    String
  location       String?
  salaryMin      Int?
  salaryMax      Int?
  employmentType EmploymentType @default(FULL_TIME)
  isPublished    Boolean        @default(true)
  isDeleted      Boolean        @default(false)
  viewCount      Int            @default(0)
  categoryTag    String?
  tags           String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // 追加フィールド（WP準拠）
  imageUrl              String?   // メイン画像
  requirements          String?   // 応募条件
  desiredAptitude       String?   // 求む適性
  recommendedFor        String?   // おすすめしたい方へ
  monthlySalary         String?   // 給与（税込月給）
  annualSalary          String?   // 給与（税込年収）
  access                String?   // アクセス
  officeName            String?   // 勤務地名称
  officeDetail          String?   // 勤務地名称詳細
  benefits              String[]  // 福利厚生
  selectionProcess      String?   // 選考プロセス
  workingHours          String?   // 勤務時間
  closingDate           DateTime? // 掲載終了日
  employmentPeriodType  String?   // 有期/無期雇用区分
  region                String?   // 勤務地エリア（北海道・東北等）
  categoryTagDetail     String?   // カテゴリ「その他」の詳細
  employmentTypeDetail  String?   // 雇用形態「その他」の詳細

  // ターゲット（新卒/中途）
  targetType            String    @default("MID_CAREER") // "NEW_GRAD" | "MID_CAREER"
  graduationYear        Int?      // 新卒の場合の卒業年度（例: 2027）

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  bookmarks    Bookmark[]
  favorites    Favorite[]
  jobViews     JobView[]
}

model Application {
  id         String            @id @default(cuid())
  userId     String
  jobId      String
  motivation String?
  status     ApplicationStatus @default(APPLIED)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  conversation    Conversation?
  charge          Charge?
  invalidRequests InvalidRequest[]

  @@unique([userId, jobId])
}

model Conversation {
  id            String   @id @default(cuid())
  applicationId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderId       String
  senderType     MessageSenderType
  body           String
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  isRead         Boolean           @default(false)
  createdAt      DateTime          @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  rating    Int
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

// ---- 料金表 ----

model PriceEntry {
  id                 String  @id @default(cuid())
  category           String  // 大カテゴリ (営業, IT, etc.)
  subcategory        String  // 職種名
  experiencedPrice   Int     // 経験者料金
  inexperiencedPrice Int?    // 未経験者料金 (nullable)
  sortOrder          Int     @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([category, sortOrder])
}

// ---- 課金・請求・分析 ----

enum InvalidRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Charge {
  id            String   @id @default(cuid())
  applicationId String   @unique
  amount        Int
  isValid       Boolean  @default(true)
  billingMonth  String   // YYYY-MM
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model InvalidRequest {
  id            String               @id @default(cuid())
  applicationId String
  companyId     String
  reason        String
  status        InvalidRequestStatus @default(PENDING)
  deadline      DateTime
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model MonthlyBilling {
  id           String    @id @default(cuid())
  companyId    String
  billingMonth String    // YYYY-MM
  totalAmount  Int
  isFinalized  Boolean   @default(false)
  finalizedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, billingMonth])
}

model JobView {
  id        String   @id @default(cuid())
  jobId     String
  viewedAt  DateTime @default(now())
  sessionId String?

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, viewedAt])
}
